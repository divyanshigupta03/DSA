class Solution {
    public ArrayList<Node> findPreSuc(Node root, int key) {
        // code here
        ArrayList<Node> ans = new ArrayList<>();
        ans.add(predecessor(root, key));
        ans.add(successor(root, key));
        return ans;
    }
    
    public Node successor(Node root, int key){
        Node successor = null;
        while(root != null){
            if(key >= root.data){
                root = root.right;
            }else{
                successor = root;
                root = root.left;
            }
        }
        return successor;
    }
    
    public Node predecessor(Node root, int key){
        Node predecessor = null;
        while(root != null){
            if(key > root.data){
                predecessor = root;
                root = root.right;
            }else{
                root = root.left;
            }
        }
        return predecessor;
    }
}
